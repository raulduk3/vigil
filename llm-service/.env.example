# LLM Service Environment Configuration

# Server
PORT=8000
HOST=0.0.0.0

# vLLM Configuration
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
MODEL_PATH=/models
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.9

# Inference Settings
MAX_MODEL_LEN=4096
MAX_TOKENS=512
TEMPERATURE=0.1

# API Keys (for private network access)
API_KEY=change-this-in-production

# Logging
LOG_LEVEL=info

# Health Check
HEALTH_CHECK_INTERVAL_SECONDS=30
