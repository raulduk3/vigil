# Backend Environment Configuration

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# LLM Service (network-routed)
LLM_SERVICE_URL=http://llm-service:8000
LLM_SERVICE_TIMEOUT_MS=30000

# SMTP Adapter (network-routed)
SMTP_ADAPTER_URL=http://smtp-adapter:2525

# Database (for event store - PostgreSQL recommended)
DATABASE_URL=postgresql://user:password@localhost:5432/vigil_events

# Notification Service (future)
NOTIFICATION_SERVICE_URL=http://notifications:4000

# JWT Secret (for API authentication)
JWT_SECRET=change-this-in-production

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://frontend:5173

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
