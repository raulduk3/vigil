# Vigil Backend Configuration
# Copy to .env and customize for your environment

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vigil
DB_USER=vigil
DB_PASSWORD=vigil
DB_MAX_CONNECTIONS=20

# Legacy DATABASE_URL format (alternative to individual DB_* vars)
# DATABASE_URL=postgresql://vigil:vigil@localhost:5432/vigil

# JWT Secrets (REQUIRED - Generate with: openssl rand -base64 32)
# These MUST be set - the application will not start without them
JWT_SECRET=JW5Xk3m6juSEHrZ4G4JLUY7Jk8K62+QWVKH69QDVplg
JWT_REFRESH_SECRET=DSTHXBvVwKfvhTLGkrY4J13SBxWfM4Te+RsvLxxVayo

# Scheduler
SCHEDULER_TICK_INTERVAL_MS=60000
SCHEDULER_ENABLED=true

# Notification Worker
NOTIFICATION_POLL_INTERVAL_MS=5000
NOTIFICATION_WORKER_ENABLED=true

# LLM Service (network-routed)
LLM_SERVICE_URL=http://llm-service:8000
LLM_SERVICE_TIMEOUT_MS=30000

# Resend API (outbound email)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Sender addresses (override defaults from resend-config.ts)
# Default: notifications@vigil.run
RESEND_FROM_EMAIL=notifications@vigil.run
RESEND_FROM_NAME=Vigil Alerts

# Resend webhook secret (for bounce/complaint webhooks)
# Get from https://resend.com/webhooks after creating webhook
# RESEND_WEBHOOK_SECRET=whsec_xxx

# Alternative API URL (for testing/proxy)
# RESEND_API_URL=https://api.resend.com

# Request timeout
# RESEND_TIMEOUT_MS=30000

# Cloudflare Email Routing (inbound email)
# Webhook endpoint: POST /api/ingestion/cloudflare-email
# Configure in Cloudflare dashboard to forward to this endpoint

# Notification Service (future)
NOTIFICATION_SERVICE_URL=http://notifications:4000

# CORS Origins (comma-separated, use * for development)
# Include your frontend origin(s). For production add https://vigil.run
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://frontend:5173

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# Application URLs
# ============================================================================
# Base URL for the application (used for email links, OAuth callbacks)
APP_BASE_URL=http://localhost:3000
# Production: https://vigil.run

# ============================================================================
# Webhook Security
# ============================================================================
# Secret used for HMAC signing outbound webhooks
# Generate with: openssl rand -hex 32
# WEBHOOK_SIGNING_SECRET=your-secret-here

# ============================================================================
# Stripe Integration (Billing)
# ============================================================================
# Get these from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_... (required for checkout/portal)
# STRIPE_WEBHOOK_SECRET=whsec_... (required for webhook verification)

# Stripe Price IDs for each tier
# Create products/prices in Stripe Dashboard and copy the price IDs here
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_... (optional, for sales-only tier)

# ============================================================================
# OAuth Providers
# ============================================================================
# Google OAuth - Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=863963573242-6p2u9vs27bu8268li90jpl39oupkq6ua.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# GitHub OAuth - Get from https://github.com/settings/developers
GITHUB_CLIENT_ID=Ov23lipa165XCXiJWK4Y
GITHUB_CLIENT_SECRET=
# Frontend
FRONTEND_URL=http://localhost:3000
# Production: https://vigil.run
