# Vigil V2 Backend Configuration
# Copy to .env and fill in your values.

# ============================================================================
# Server
# ============================================================================
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# ============================================================================
# Database (SQLite — V2)
# ============================================================================
# Relative to backend/ directory
DB_PATH=./data/vigil.db

# ============================================================================
# JWT Secrets (REQUIRED)
# Generate with: openssl rand -base64 32
# ============================================================================
JWT_SECRET=
JWT_REFRESH_SECRET=

# ============================================================================
# LLM — OpenAI API (REQUIRED for agent)
# ============================================================================
OPENAI_API_KEY=

# Default model (override per-watcher in the UI)
# Options: gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, gpt-4o, gpt-4o-mini
VIGIL_MODEL=gpt-4.1-mini

# ============================================================================
# Resend (outbound alerts) (REQUIRED)
# Get API key from https://resend.com/api-keys
# ============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@vigil.run
RESEND_FROM_NAME=Vigil

# ============================================================================
# Application URLs
# ============================================================================
# Backend public URL (used for email action links)
API_URL=http://localhost:4000
# Backend base URL (used for OAuth callbacks)
APP_BASE_URL=http://localhost:4000
# Frontend URL (used for OAuth redirects, CORS)
FRONTEND_URL=http://localhost:3000
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ============================================================================
# Webhook Security (REQUIRED if using webhook tool)
# Generate with: openssl rand -hex 32
# ============================================================================
# WEBHOOK_SIGNING_SECRET=

# ============================================================================
# Stripe Billing (REQUIRED for paid usage)
# Get from https://dashboard.stripe.com/apikeys
# ============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# OAuth Providers (optional)
# ============================================================================
# Google: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ============================================================================
# BYOK Encryption (REQUIRED for user-provided API keys)
# Generate with: openssl rand -hex 32
# ============================================================================
ENCRYPTION_KEY=

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
