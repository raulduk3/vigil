# SMTP Adapter Environment Configuration

# SMTP Server
SMTP_PORT=2525
SMTP_HOST=0.0.0.0

# Backend API (network-routed)
BACKEND_API_URL=http://backend:3000
BACKEND_API_KEY=change-this-in-production

# SMTP Settings
MAX_MESSAGE_SIZE_MB=25
SMTP_BANNER=Vigil SMTP Ingress Adapter

# Security
ALLOWED_SENDER_DOMAINS=example.com,trusted-domain.com
REJECT_INVALID_DKIM=false
REQUIRE_TLS=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
MAX_CONNECTIONS=100
RATE_LIMIT_PER_SENDER=60
