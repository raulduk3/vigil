# Vigil Frontend Environment Configuration

# ============================================================================
# Backend API
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
# Production: https://api.vigil.run

# ============================================================================
# App Configuration
# ============================================================================
NEXT_PUBLIC_APP_NAME=Vigil
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://vigil.run

# ============================================================================
# Stripe (Client-side publishable key only)
# ============================================================================
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ============================================================================
# Feature Flags (Optional - backend controls actual availability)
# ============================================================================
# These only control UI display; backend validates actual OAuth config
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED=true
